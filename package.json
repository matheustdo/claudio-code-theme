{
  "name": "claudio-code-theme",
  "displayName": "Claudio Code Theme",
  "description": "A warm terracotta-and-cream theme pair (dark + light) — soft backgrounds, pastel syntax, and muted accents for long coding sessions.",
  "version": "1.0.0",
  "publisher": "claude-code-theme",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "dark",
    "light",
    "theme",
    "warm",
    "terracotta",
    "pastel"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Claudio Code Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/claudio-code-dark.json"
      },
      {
        "label": "Claudio Code Light",
        "uiTheme": "vs",
        "path": "./themes/claudio-code-light.json"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/claudio-code-theme"
  },
  "license": "MIT"
}
