  "tokenColors": [
    { "name": "Comment", "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#787878", "fontStyle": "italic" } },
    { "name": "Comment doc", "scope": ["comment.block.documentation"], "settings": { "foreground": "#8a8a86", "fontStyle": "italic" } },
    { "name": "Keyword", "scope": ["keyword", "keyword.control", "keyword.operator.new", "storage.type", "storage.modifier"], "settings": { "foreground": "#e07890" } },
    { "name": "Keyword import", "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from", "keyword.control.as"], "settings": { "foreground": "#e07890" } },
    { "name": "String", "scope": ["string", "string.quoted", "string.template"], "settings": { "foreground": "#a2c892" } },
    { "name": "String escape", "scope": ["constant.character.escape"], "settings": { "foreground": "#c89050" } },
    { "name": "Template expr", "scope": ["punctuation.definition.template-expression", "punctuation.section.embedded"], "settings": { "foreground": "#e07890" } },
    { "name": "Number", "scope": ["constant.numeric"], "settings": { "foreground": "#e07890" } },
    { "name": "Boolean/null", "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined"], "settings": { "foreground": "#e07890" } },
    { "name": "Constant", "scope": ["constant.language", "constant.other"], "settings": { "foreground": "#e07890" } },
    { "name": "Function decl", "scope": ["entity.name.function", "meta.function entity.name.function"], "settings": { "foreground": "#b294da" } },
    { "name": "Function call", "scope": ["meta.function-call entity.name.function", "support.function"], "settings": { "foreground": "#b294da" } },
    { "name": "Variable", "scope": ["variable", "variable.other"], "settings": { "foreground": "#e0e0de" } },
    { "name": "Parameter", "scope": ["variable.parameter"], "settings": { "foreground": "#d97757" } },
    { "name": "Variable language", "scope": ["variable.language"], "settings": { "foreground": "#e07890", "fontStyle": "italic" } },
    { "name": "Property", "scope": ["variable.other.property", "support.variable.property"], "settings": { "foreground": "#e0e0de" } },
    { "name": "Type/Class", "scope": ["entity.name.type", "entity.name.class", "entity.name.interface", "entity.name.enum", "entity.other.inherited-class", "support.class"], "settings": { "foreground": "#b294da" } },
    { "name": "Type annotation", "scope": ["support.type", "entity.name.type.primitive"], "settings": { "foreground": "#b294da" } },
    { "name": "Decorator", "scope": ["meta.decorator", "entity.name.decorator", "punctuation.decorator"], "settings": { "foreground": "#8bc4c8" } },
    { "name": "Object key", "scope": ["meta.object-literal.key", "support.type.property-name"], "settings": { "foreground": "#e0e0de" } },
    { "name": "Operator", "scope": ["keyword.operator"], "settings": { "foreground": "#e07890" } },
    { "name": "Punctuation", "scope": ["punctuation", "meta.brace", "meta.delimiter"], "settings": { "foreground": "#8a8a8a" } },
    { "name": "Tag name", "scope": ["entity.name.tag"], "settings": { "foreground": "#a2c892" } },
    { "name": "Tag attribute", "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#8bc4c8" } },
    { "name": "Tag punctuation", "scope": ["punctuation.definition.tag"], "settings": { "foreground": "#6a6a6a" } },
    { "name": "HTML string", "scope": ["string.quoted.double.html", "string.quoted.single.html"], "settings": { "foreground": "#a2c892" } },
    { "name": "CSS property", "scope": ["support.type.property-name.css"], "settings": { "foreground": "#8bc4c8" } },
    { "name": "CSS value", "scope": ["support.constant.property-value.css"], "settings": { "foreground": "#a2c892" } },
    { "name": "CSS selector", "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"], "settings": { "foreground": "#8bc4c8" } },
    { "name": "CSS unit", "scope": ["constant.numeric.css", "keyword.other.unit.css"], "settings": { "foreground": "#e07890" } },
    { "name": "CSS at-rule", "scope": ["keyword.control.at-rule.css"], "settings": { "foreground": "#e07890" } },
    { "name": "JSON key", "scope": ["support.type.property-name.json"], "settings": { "foreground": "#8bc4c8" } },
    { "name": "MD heading", "scope": ["markup.heading", "punctuation.definition.heading"], "settings": { "foreground": "#e07890", "fontStyle": "bold" } },
    { "name": "MD bold", "scope": ["markup.bold"], "settings": { "foreground": "#e0e0de", "fontStyle": "bold" } },
    { "name": "MD italic", "scope": ["markup.italic"], "settings": { "foreground": "#e0e0de", "fontStyle": "italic" } },
    { "name": "MD code", "scope": ["markup.inline.raw", "markup.fenced_code.block"], "settings": { "foreground": "#8bc4c8" } },
    { "name": "MD link", "scope": ["markup.underline.link", "string.other.link"], "settings": { "foreground": "#8fb3e0" } },
    { "name": "MD list", "scope": ["markup.list", "punctuation.definition.list"], "settings": { "foreground": "#e07890" } },
    { "name": "MD quote", "scope": ["markup.quote"], "settings": { "foreground": "#787878", "fontStyle": "italic" } },
    { "name": "Invalid", "scope": ["invalid"], "settings": { "foreground": "#dd6a6e", "fontStyle": "underline" } },
    { "name": "Deprecated", "scope": ["invalid.deprecated"], "settings": { "foreground": "#787878", "fontStyle": "strikethrough" } }
  ],
  "semanticTokenColors": {
    "namespace":            { "foreground": "#b294da" },
    "class":                { "foreground": "#b294da" },
    "class.declaration":    { "foreground": "#b294da" },
    "interface":            { "foreground": "#b294da" },
    "enum":                 { "foreground": "#b294da" },
    "enumMember":           { "foreground": "#e07890" },
    "function":             { "foreground": "#b294da" },
    "function.declaration": { "foreground": "#b294da" },
    "function.readonly":    { "foreground": "#e0e0de" },
    "function.local":       { "foreground": "#e0e0de" },
    "method":               { "foreground": "#b294da" },
    "method.declaration":   { "foreground": "#b294da" },
    "property":             { "foreground": "#e0e0de" },
    "property.declaration": { "foreground": "#e0e0de" },
    "variable":             { "foreground": "#e0e0de" },
    "variable.declaration": { "foreground": "#78b8ff" },
    "variable.readonly":    { "foreground": "#78b8ff" },
    "parameter":            { "foreground": "#d97757" },
    "type":                 { "foreground": "#b294da" },
    "typeParameter":        { "foreground": "#b294da" },
    "keyword":              { "foreground": "#e07890" },
    "modifier":             { "foreground": "#e07890" },
    "string":               { "foreground": "#a2c892" },
    "number":               { "foreground": "#e07890" },
    "regexp":               { "foreground": "#a2c892" },
    "operator":             { "foreground": "#e07890" },
    "decorator":            { "foreground": "#8bc4c8" },
    "macro":                { "foreground": "#e07890" },
    "label":                { "foreground": "#e0e0de" },
    "comment":              { "foreground": "#787878", "italic": true },
    "selfKeyword":          { "foreground": "#e07890", "italic": true },
    "builtinType":          { "foreground": "#b294da" }
  }
}
