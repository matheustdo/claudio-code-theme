  "tokenColors": [
    { "name": "Comment", "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#707070", "fontStyle": "italic" } },
    { "name": "Comment doc", "scope": ["comment.block.documentation"], "settings": { "foreground": "#808078", "fontStyle": "italic" } },
    { "name": "Keyword", "scope": ["keyword", "keyword.control", "keyword.operator.new", "storage.type", "storage.modifier"], "settings": { "foreground": "#c74468" } },
    { "name": "Keyword import", "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from", "keyword.control.as"], "settings": { "foreground": "#c74468" } },
    { "name": "String", "scope": ["string", "string.quoted", "string.template"], "settings": { "foreground": "#3e8a4e" } },
    { "name": "String escape", "scope": ["constant.character.escape"], "settings": { "foreground": "#a06820" } },
    { "name": "Template expr", "scope": ["punctuation.definition.template-expression", "punctuation.section.embedded"], "settings": { "foreground": "#c74468" } },
    { "name": "Number", "scope": ["constant.numeric"], "settings": { "foreground": "#c74468" } },
    { "name": "Boolean/null", "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined"], "settings": { "foreground": "#c74468" } },
    { "name": "Constant", "scope": ["constant.language", "constant.other"], "settings": { "foreground": "#c74468" } },
    { "name": "Function decl", "scope": ["entity.name.function", "meta.function entity.name.function"], "settings": { "foreground": "#7b4cbf" } },
    { "name": "Function call", "scope": ["meta.function-call entity.name.function", "support.function"], "settings": { "foreground": "#7b4cbf" } },
    { "name": "Variable", "scope": ["variable", "variable.other"], "settings": { "foreground": "#1a1a1a" } },
    { "name": "Parameter", "scope": ["variable.parameter"], "settings": { "foreground": "#b55a30" } },
    { "name": "Variable language", "scope": ["variable.language"], "settings": { "foreground": "#c74468", "fontStyle": "italic" } },
    { "name": "Property", "scope": ["variable.other.property", "support.variable.property"], "settings": { "foreground": "#1a1a1a" } },
    { "name": "Type/Class", "scope": ["entity.name.type", "entity.name.class", "entity.name.interface", "entity.name.enum", "entity.other.inherited-class", "support.class"], "settings": { "foreground": "#7b4cbf" } },
    { "name": "Type annotation", "scope": ["support.type", "entity.name.type.primitive"], "settings": { "foreground": "#7b4cbf" } },
    { "name": "Decorator", "scope": ["meta.decorator", "entity.name.decorator", "punctuation.decorator"], "settings": { "foreground": "#3a8590" } },
    { "name": "Object key", "scope": ["meta.object-literal.key", "support.type.property-name"], "settings": { "foreground": "#1a1a1a" } },
    { "name": "Operator", "scope": ["keyword.operator"], "settings": { "foreground": "#c74468" } },
    { "name": "Punctuation", "scope": ["punctuation", "meta.brace", "meta.delimiter"], "settings": { "foreground": "#707070" } },
    { "name": "Tag name", "scope": ["entity.name.tag"], "settings": { "foreground": "#3e8a4e" } },
    { "name": "Tag attribute", "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#3a8590" } },
    { "name": "Tag punctuation", "scope": ["punctuation.definition.tag"], "settings": { "foreground": "#8a8a8a" } },
    { "name": "HTML string", "scope": ["string.quoted.double.html", "string.quoted.single.html"], "settings": { "foreground": "#3e8a4e" } },
    { "name": "CSS property", "scope": ["support.type.property-name.css"], "settings": { "foreground": "#3a8590" } },
    { "name": "CSS value", "scope": ["support.constant.property-value.css"], "settings": { "foreground": "#3e8a4e" } },
    { "name": "CSS selector", "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"], "settings": { "foreground": "#3a8590" } },
    { "name": "CSS unit", "scope": ["constant.numeric.css", "keyword.other.unit.css"], "settings": { "foreground": "#c74468" } },
    { "name": "CSS at-rule", "scope": ["keyword.control.at-rule.css"], "settings": { "foreground": "#c74468" } },
    { "name": "JSON key", "scope": ["support.type.property-name.json"], "settings": { "foreground": "#3a8590" } },
    { "name": "MD heading", "scope": ["markup.heading", "punctuation.definition.heading"], "settings": { "foreground": "#c74468", "fontStyle": "bold" } },
    { "name": "MD bold", "scope": ["markup.bold"], "settings": { "foreground": "#1a1a1a", "fontStyle": "bold" } },
    { "name": "MD italic", "scope": ["markup.italic"], "settings": { "foreground": "#1a1a1a", "fontStyle": "italic" } },
    { "name": "MD code", "scope": ["markup.inline.raw", "markup.fenced_code.block"], "settings": { "foreground": "#3a8590" } },
    { "name": "MD link", "scope": ["markup.underline.link", "string.other.link"], "settings": { "foreground": "#3060b0" } },
    { "name": "MD list", "scope": ["markup.list", "punctuation.definition.list"], "settings": { "foreground": "#c74468" } },
    { "name": "MD quote", "scope": ["markup.quote"], "settings": { "foreground": "#8a8a8a", "fontStyle": "italic" } },
    { "name": "Invalid", "scope": ["invalid"], "settings": { "foreground": "#c04040", "fontStyle": "underline" } },
    { "name": "Deprecated", "scope": ["invalid.deprecated"], "settings": { "foreground": "#8a8a8a", "fontStyle": "strikethrough" } }
  ],
  "semanticTokenColors": {
    "namespace":            { "foreground": "#7b4cbf" },
    "class":                { "foreground": "#7b4cbf" },
    "class.declaration":    { "foreground": "#7b4cbf" },
    "interface":            { "foreground": "#7b4cbf" },
    "enum":                 { "foreground": "#7b4cbf" },
    "enumMember":           { "foreground": "#c74468" },
    "function":             { "foreground": "#7b4cbf" },
    "function.declaration": { "foreground": "#7b4cbf" },
    "function.readonly":    { "foreground": "#1a1a1a" },
    "function.local":       { "foreground": "#1a1a1a" },
    "method":               { "foreground": "#7b4cbf" },
    "method.declaration":   { "foreground": "#7b4cbf" },
    "property":             { "foreground": "#1a1a1a" },
    "property.declaration": { "foreground": "#1a1a1a" },
    "variable":             { "foreground": "#1a1a1a" },
    "variable.declaration": { "foreground": "#2f70d4" },
    "variable.readonly":    { "foreground": "#2f70d4" },
    "parameter":            { "foreground": "#b55a30" },
    "type":                 { "foreground": "#7b4cbf" },
    "typeParameter":        { "foreground": "#7b4cbf" },
    "keyword":              { "foreground": "#c74468" },
    "modifier":             { "foreground": "#c74468" },
    "string":               { "foreground": "#3e8a4e" },
    "number":               { "foreground": "#c74468" },
    "regexp":               { "foreground": "#3e8a4e" },
    "operator":             { "foreground": "#c74468" },
    "decorator":            { "foreground": "#3a8590" },
    "macro":                { "foreground": "#c74468" },
    "label":                { "foreground": "#1a1a1a" },
    "comment":              { "foreground": "#707070", "italic": true },
    "selfKeyword":          { "foreground": "#c74468", "italic": true },
    "builtinType":          { "foreground": "#7b4cbf" }
  }
}
